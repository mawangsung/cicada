# Copy to .env and fill in your values.
# Never commit .env to source control.

# Required: HuggingFace access token
HF_TOKEN=hf_...

# Required for Sensor Upload tab (HuggingFace Dataset source)
HF_DATASET_REPO=username/odin-sensor-data

# Optional: separate repo for storing circuit results as JSON
# If unset, the "Push result to HF" checkbox has no effect.
HF_CIRCUIT_REPO=username/odin-circuits
